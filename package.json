{
  "name": "@karinjs/plugin-puppeteer",
  "version": "1.1.2",
  "description": "karin 的 puppeteer 截图、渲染插件",
  "keywords": [
    "karin",
    "node-karin",
    "karin-plugin",
    "puppeteer",
    "browser",
    "headless"
  ],
  "license": "MIT",
  "author": "sj817",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && tsup",
    "dev": "tsx src/app.ts",
    "dev:test": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "pub": "pnpm publish --access public",
    "rm": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "lint": "eslint src/",
    "sync": "curl -X PUT \"https://registry-direct.npmmirror.com/-/package/@karinjs/plugin-puppeteer/syncs\""
  },
  "dependencies": {
    "@snapka/puppeteer": "0.1.5"
  },
  "devDependencies": {
    "@types/node": "^22.5.4",
    "eslint": "latest",
    "neostandard": "latest",
    "node-karin": "^1.13.0",
    "tsup": "^8.4.0",
    "typescript": "5.4.5",
    "vitest": "^3.0.0"
  },
  "karin": {
    "main": "src/index.ts",
    "apps": [],
    "web": "dist/web.config.js",
    "ts-web": "src/web.config.ts",
    "files": [
      "config"
    ]
  }
}